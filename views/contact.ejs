<%- include('partials/head', { title: 'Contact Us' }) %>
<%- include('partials/header', { page: 'contact' }) %>

    <!-- Page Header -->
    <section class="pt-32 pb-20 bg-emerald-900 relative overflow-hidden text-center">
        <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/islamic-art.png')]"></div>
        <div class="max-w-7xl mx-auto px-4 relative z-10">
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">Get In Touch</h1>
            <p class="text-emerald-100 max-w-2xl mx-auto text-lg font-light">We are here to answer your questions and support you in any way we can.</p>
        </div>
    </section>

    <!-- Contact Form & Info -->
    <section class="py-24 px-4">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-3 gap-16">
            <!-- Contact Info -->
            <div class="lg:col-span-1 space-y-8 reveal">
                <div>
                    <h3 class="text-2xl font-bold text-emerald-950 mb-6">Our Location</h3>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-emerald-50 text-emerald-800 rounded-xl flex items-center justify-center text-xl shrink-0">
                            <i class="fa-solid fa-location-dot"></i>
                        </div>
                        <div>
                            <p class="font-bold text-emerald-900">Address</p>
                            <p class="text-gray-600">The Kings Centre, Moat Road, East Grinstead, RH19 3LN, England</p>
                        </div>
                    </div>
                </div>

                <div class="flex items-start space-x-4">
                    <div class="w-12 h-12 bg-emerald-50 text-emerald-800 rounded-xl flex items-center justify-center text-xl shrink-0">
                        <i class="fa-solid fa-phone"></i>
                    </div>
                    <div>
                        <p class="font-bold text-emerald-900">Phone</p>
                        <p class="text-gray-600">K N Naser 07943 017215</p>
                        <p class="text-gray-600">Kaher Uddin 07487 550612</p>
                    </div>
                </div>

                <div class="flex items-start space-x-4">
                    <div class="w-12 h-12 bg-emerald-50 text-emerald-800 rounded-xl flex items-center justify-center text-xl shrink-0">
                        <i class="fa-solid fa-envelope"></i>
                    </div>
                    <div>
                        <p class="font-bold text-emerald-900">Email</p>
                        <p class="text-gray-600">info@egmuslimcommunity.co.uk</p>
                    </div>
                </div>

                <!-- Google Map Embed -->
                <div class="pt-8">
                    <h4 class="font-bold text-emerald-950 mb-4 uppercase tracking-widest text-sm">Find Us</h4>
                    <div class="rounded-2xl overflow-hidden shadow-sm border border-emerald-50 h-[450px] w-full">
                        <iframe 
                            width="100%" 
                            height="100%" 
                            frameborder="0" 
                            style="border:0"
                            src="https://maps.google.com/maps?q=The%20Kings%20Centre%20Moat%20Road%20East%20Grinstead%20RH19%203LN%20England&t=&z=15&ie=UTF8&iwloc=&output=embed" 
                            allowfullscreen>
                        </iframe>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="lg:col-span-2 reveal" style="transition-delay: 200ms;">
                <div class="bg-white p-10 rounded-3xl shadow-sm border border-emerald-50">
                    <h3 class="text-2xl font-bold text-emerald-950 mb-8">Send us a Message</h3>
                    <form id="contact-form" class="space-y-6">
                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                                <input type="text" name="name" required class="w-full bg-cream-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-gold-500 transition-all" placeholder="Enter your name">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                                <input type="email" name="email" required class="w-full bg-cream-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-gold-500 transition-all" placeholder="Enter your email">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Subject</label>
                            <input type="text" name="subject" required class="w-full bg-cream-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-gold-500 transition-all" placeholder="How can we help?">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Message</label>
                            <textarea name="message" required rows="5" class="w-full bg-cream-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-gold-500 transition-all" placeholder="Your message here..."></textarea>
                        </div>
                        <button type="submit" class="btn-gold w-full py-4 text-lg">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
