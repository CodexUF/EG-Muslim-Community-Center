<%- include('partials/head', { title: 'About Us' }) %>
<%- include('partials/header', { page: 'about' }) %>

    <!-- Page Header -->
    <section class="pt-32 pb-20 bg-emerald-900 relative overflow-hidden text-center">
        <!-- Ken Burns Header -->
        <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1551041777-ed938559104c?auto=format&fit=crop&q=80&w=2000')] bg-cover bg-center animate-ken-burns opacity-30"></div>
        <div class="absolute inset-0 bg-emerald-900/60"></div>
        <div class="max-w-7xl mx-auto px-4 relative z-10">
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">About Our Centre</h1>
        </div>
    </section>

    <!-- History Section -->
    <section class="py-24 px-4">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
            <div class="reveal">
                <span class="text-gold-500 font-bold uppercase tracking-widest text-sm">Our Legacy</span>
                <h2 class="text-4xl font-bold text-emerald-950 mt-2 mb-6 font-serif">A Foundation Built on Faith</h2>
                <p class="text-gray-600 leading-relaxed mb-6">
                    All praise is due to Allah, and may blessings and peace be upon His Messenger.
                </p>
                <p class="text-gray-600 leading-relaxed mb-6">
                    We would like to inform you that, due to the small number of Muslims in our East Grinstead area, a mosque has not yet been established here. Therefore, every Friday, we rent a hall to perform the Jumu’ah prayer.
                </p>

                <p class="text-gray-600 leading-relaxed mb-8">
                    In addition, we are making earnest efforts so that, very soon, we can build a permanent mosque here. We have firm faith that, by the infinite mercy and help of Allah, we will soon be able to establish a mosque in the East Grinstead area, insha’Allah.
                </p>
                <p class="text-gray-600 leading-relaxed mb-6">
                    May Allah accept this effort from us and make it easy. Ameen.
                </p>
                <div class="grid grid-cols-2 gap-6">
                    <div class="p-6 bg-white rounded-xl shadow-sm border-l-4 border-gold-500">
                        <span class="text-3xl font-bold text-emerald-900 block">Weekly</span>
                        <span class="text-sm text-gray-500 uppercase tracking-wider">Jumu’ah Prayers</span>
                    </div>
                    <div class="p-6 bg-white rounded-xl shadow-sm border-l-4 border-emerald-800">
                        <span class="text-3xl font-bold text-emerald-900 block">1,000+</span>
                        <span class="text-sm text-gray-500 uppercase tracking-wider">Community Members</span>
                    </div>
                    
                </div>
            </div>
            <div class="reveal lg:pl-10">
                <!-- Gallery Container -->
                <div class="grid grid-cols-2 gap-6 relative">
                    <!-- Image 1 -->
                    <div class="group relative overflow-hidden rounded-2xl shadow-lg aspect-square border-4 border-white">
                        <img src="asset/img1.webp" alt="Mosque Perspective" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                            <span class="text-white font-serif text-sm tracking-widest uppercase">Exterior View</span>
                        </div>
                    </div>

                    <!-- Image 2 -->
                    <div class="group relative overflow-hidden rounded-2xl shadow-lg aspect-square border-4 border-white">
                        <img src="asset/img2.webp" alt="Mosque Interior" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                            <span class="text-white font-serif text-sm tracking-widest uppercase">Interior Space</span>
                        </div>
                    </div>

                    <!-- Image 3 -->
                    <div class="group relative overflow-hidden rounded-2xl shadow-lg aspect-square border-4 border-white">
                        <img src="asset/img3.webp" alt="Community Area" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                            <span class="text-white font-serif text-sm tracking-widest uppercase">Community Hall</span>
                        </div>
                    </div>

                    <!-- Image 4 -->
                    <div class="group relative overflow-hidden rounded-2xl shadow-lg aspect-square border-4 border-white">
                        <img src="asset/img4.webp" alt="Architectural Detail" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                        <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                            <span class="text-white font-serif text-sm tracking-widest uppercase">Islamic Architecture</span>
                        </div>
                    </div>

                    <!-- Decorative Gold Accent -->
                    <div class="absolute -inset-4 border border-gold-400/20 rounded-[2.5rem] -z-10"></div>
                </div>
                
                <!-- Caption -->
                <p class="mt-8 text-center text-emerald-800/60 font-serif italic">
                    Capturing the beauty and spirit of E G Muslim Community Centre
                </p>
            </div>
        </div>
    </section>

    <!-- Vision & Mission -->
    <section class="py-24 px-4 bg-emerald-50">
        <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-10">
            <div class="bg-white p-10 rounded-2xl shadow-sm reveal">
                <h3 class="text-2xl font-bold text-emerald-900 mb-4">Our Vision</h3>
                <p class="text-gray-600 leading-relaxed">To be a model Islamic community centre that inspires spiritual growth and serves as a bridge for intercultural understanding.</p>
            </div>
            <div class="bg-white p-10 rounded-2xl shadow-sm reveal" style="transition-delay: 200ms;">
                <h3 class="text-2xl font-bold text-emerald-900 mb-4">Our Mission</h3>
                <p class="text-gray-600 leading-relaxed">Providing high-quality spiritual, educational, and social services that empower individuals to lead a God-conscious life.</p>
            </div>
            <div class="bg-white p-10 rounded-2xl shadow-sm reveal" style="transition-delay: 400ms;">
                <h3 class="text-2xl font-bold text-emerald-900 mb-4">Our Values</h3>
                <p class="text-gray-600 leading-relaxed">Excellence, Integrity, Compassion, and Inclusivity are at the core of everything we do for our community.</p>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
