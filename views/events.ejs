<%- include('partials/head', { title: 'Events' }) %>
<%- include('partials/header', { page: 'events' }) %>

    <!-- Page Header -->
    <section class="pt-32 pb-20 bg-emerald-900 relative overflow-hidden text-center">
        <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/islamic-art.png')]"></div>
        <div class="max-w-7xl mx-auto px-4 relative z-10">
            <h1 class="text-4xl md:text-6xl font-bold text-white mb-4">Upcoming Events</h1>
            <p class="text-emerald-100 max-w-2xl mx-auto text-lg font-light">Join us in our community gatherings, lectures, and celebrations.</p>
        </div>
    </section>

    <!-- Events Timeline -->
    <section class="py-24 px-4">
        <div class="max-w-4xl mx-auto space-y-12">
            <!-- Event 1 -->
            <div class="bg-white rounded-2xl shadow-sm overflow-hidden flex flex-col md:flex-row reveal">
                <div class="md:w-1/3 bg-gold-500 text-white p-8 flex flex-col justify-center items-center">
                    <span class="text-4xl font-bold">11</span>
                    <span class="text-xl uppercase tracking-widest">March</span>
                    <span class="mt-4 bg-white/20 px-3 py-1 rounded-full text-xs">2026</span>
                </div>
                <div class="md:w-2/3 p-8">
                    <span class="text-gold-500 font-bold text-sm uppercase">Ramadan 2026</span>
                    <h3 class="text-2xl font-bold text-emerald-950 mt-1 mb-4">First Day of Ramadan</h3>
                    <p class="text-gray-600 mb-6">Join us for the first Taraweeh prayers and community Iftar. Please check the website for the full Ramadan timetable.</p>
                    <div class="flex items-center text-emerald-800 font-medium">
                        <i class="fa-solid fa-clock mr-2"></i> After Isha Prayer
                    </div>
                </div>
            </div>

            <!-- Event 2 -->
            <div class="bg-white rounded-2xl shadow-sm overflow-hidden flex flex-col md:flex-row reveal" style="transition-delay: 150ms;">
                <div class="md:w-1/3 bg-emerald-800 text-white p-8 flex flex-col justify-center items-center">
                    <span class="text-4xl font-bold">25</span>
                    <span class="text-xl uppercase tracking-widest">April</span>
                    <span class="mt-4 bg-white/20 px-3 py-1 rounded-full text-xs">2026</span>
                </div>
                <div class="md:w-2/3 p-8">
                    <span class="text-emerald-800 font-bold text-sm uppercase">Community Youth</span>
                    <h3 class="text-2xl font-bold text-emerald-950 mt-1 mb-4">Youth Football Tournament</h3>
                    <p class="text-gray-600 mb-6">Our annual community tournament for ages 12-18. Registration required. Food and prizes for all participants.</p>
                    <div class="flex items-center text-emerald-800 font-medium">
                        <i class="fa-solid fa-location-dot mr-2"></i> Local Community Park
                    </div>
                </div>
            </div>

            <!-- Event 3 -->
            <div class="bg-white rounded-2xl shadow-sm overflow-hidden flex flex-col md:flex-row reveal" style="transition-delay: 300ms;">
                <div class="md:w-1/3 bg-gold-500 text-white p-8 flex flex-col justify-center items-center">
                    <span class="text-4xl font-bold">10</span>
                    <span class="text-xl uppercase tracking-widest">May</span>
                    <span class="mt-4 bg-white/20 px-3 py-1 rounded-full text-xs">2026</span>
                </div>
                <div class="md:w-2/3 p-8">
                    <span class="text-gold-500 font-bold text-sm uppercase">Islamic Lecture</span>
                    <h3 class="text-2xl font-bold text-emerald-950 mt-1 mb-4">The Life of Prophet Muhammad (PBUH)</h3>
                    <p class="text-gray-600 mb-6">A special evening lecture by Guest Imam on the Seerah of the Prophet and its relevance today.</p>
                    <div class="flex items-center text-emerald-800 font-medium">
                        <i class="fa-solid fa-clock mr-2"></i> 7:00 PM - 9:00 PM
                    </div>
                </div>
            </div>
        </div>
    </section>

<%- include('partials/footer') %>
